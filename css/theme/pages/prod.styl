.product-view
    --color: #999999

.prod
    &__img
        flex: 0 1 650px

        .sharing-links
            @media media-min-lg
                margin-bottom: 10px
                margin-left: 95px

    &__categories
        li:not(:first-child)
            display: none

        a
            font-weight: medium
            font-size: 14px

    &__name
        padding-bottom: 25px

        h1
            padding: 5px 0
            font-size: 24px
            line-height: 1.3

        .sku
            display: inline
            color: var(--color)
            font-weight: regular
            font-size: 14px

        .brand
            display: inline
            margin-right: 20px

            .thumb
                display: none

            a
                color: var(--color)
                font-weight: regular
                font-size: 14px
                opacity: 1

                &:before
                    content: 'Marca: '

                &:after
                    content: attr(title)

    &__short-desc
        padding-bottom: 20px

        &:before
            display: block
            padding-bottom: 10px
            color: var(--primary)
            content: 'Descrição'
            font-weight: medium
            font-size: 14px

        &.std
            color: var(--color)
            font-weight: regular
            font-size: 12px
            line-height: 16px

    &__shop
        position: relative

        .col
            @media media-min-lg
                display: flex
                flex-flow: column nowrap

        .parcelamento
            display: none

        .qty-wrapper
            flex: 0 0 80px
            margin: 0
            min-width: 0

        .add-to-cart-buttons
            display: flex

        .add-to-cart-btn
            display: flex
            justify-content: center
            align-items: center
            padding: 0
            height: 42px
            border-radius: 0 var(--border-radius) var(--border-radius) 0
            background: linear-gradient(to bottom, var(--button), var(--button-hover))
            box-shadow: none
            font-weight: bold
            font-size: 14px
            line-height: 42px

            &:before
                content: 'Adicionar ao Carrinho'

            span
                display: none

.product-image-gallery
    border-radius: var(--border-radius)
    box-shadow: 0 0 0 1px var(--color-border)

.product-image-thumbs .thumb-link
    border-radius: var(--border-radius)
    box-shadow: 0 0 0 1px var(--color-border)

@media media-min-lg
    .product-image-container
        display: flex

    .more-views
        order: -1
        margin-right: 20px
        width: 75px

    .product-image-thumbs
        display: block

@media media-min-sm
    .tabs
        &__tab.on
            padding: 0
            border: 0
            color: var(--primary)
            font-weight: medium
            font-size: 20px

        &__content
            padding: 16px 0
            border: 0

            &, .std
                color: var(--color)
                font-weight: regular
                font-size: 14px

    .product-collateral
        .title
            color: var(--primary)
            font-weight: medium
            font-size: 20px

@media media-max-sm
    .tabs
        &__tab.on
            font-weight: regular
            font-size: 14px

    .product-collateral
        .title
            font-weight: regular
            font-size: 14px