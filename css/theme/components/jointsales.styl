.jointsales
    &__payments
        display: none

    &__row
        padding: 1px

        @media media-min-sm
            flex-wrap: nowrap
            align-items: center

            .jointsales__current, .jointsales__current + .jointsales__list
                flex: 0 1 265px

            .jointsales__current
                padding: 0

            .jointsales__item
                flex: 0 0 100%
                min-width: 0
                max-width: none

            .jointsales__list
                padding: 0 !important

            .jointsales__currentin, .jointsales__item, .jointsales__all
                display: block
                padding: 16px
                border-radius: var(--border-radius)
                box-shadow: 0 0 0 1px var(--color-border)

            .jointsales__all
                flex: 0 1 350px
                align-self: center

        @media media-min-lg
            .more
                right: -80px

    &__currentin, &__list
        padding: 30px 0

    &__totals
        text-align: center

        &:before
            display: block
            padding-bottom: 20px
            color: var(--primary)
            content: 'Total comprando junto'
            text-transform: uppercase
            font-weight: bold
            font-size: 14px

        .todos-juntos
            display: none

        .comprando-junto
            font-size: 0

            .price
                color: var(--primary)
                font-weight: bold
                font-size: 24px

        .economize
            padding: 10px 0 0
            background: none
            color: var(--color)
            font-weight: regular
            font-size: 12px

            .price
                color: var(--color-text)
                font-weight: medium

    .owl-wrapper-outer
        border: 0

    .more
        display: flex
        justify-content: center
        align-items: center
        padding: 0
        width: 40px
        height: 40px
        border-radius: 50%
        background: #F8F8F8
        transform: none

        &:before
            margin-top: -12px
            color: var(--primary)
            content: '+'
            font-size: 32px

    &__action
        .btn
            width: 100%
            height: 50px
            border-radius: var(--border-radius)
            text-transform: uppercase
            font-weight: bold
            font-size: 14px

    &__currentin, &__item
        .product-collateral &
            .title
                color: var(--color-text)
                text-transform: uppercase
                font-weight: medium
                font-size: 14px

            .price span
                font-weight: bold
                font-size: 16px !important
